page { background:#f8fafc; color:#0f172a; font-family:Arial,Helvetica,sans-serif; }
.container { padding: 24rpx; }
.card { background:#fff; border-radius:20rpx; padding:24rpx; margin-bottom:24rpx; box-shadow:0 8rpx 30rpx rgba(15,23,42,.06); }
.title { font-size:34rpx; font-weight:700; }
.sub { color:#64748b; font-size:24rpx; }
.row { display:flex; align-items:center; justify-content:space-between; }
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; }
.btn-primary { background:#2563eb; color:#fff; border-radius:16rpx; padding:22rpx 24rpx; text-align:center; font-weight:700; }
.btn-secondary { background:#e2e8f0; color:#0f172a; border-radius:16rpx; padding:22rpx 24rpx; text-align:center; }
.tag { display:inline-block; padding:8rpx 16rpx; border-radius:999rpx; font-size:22rpx; }
.tag-normal { background:#dcfce7; color:#166534; }
.tag-warn { background:#fef3c7; color:#92400e; }
.tag-danger { background:#fee2e2; color:#991b1b; }
.list-item { padding:20rpx 0; border-bottom:1rpx solid #e2e8f0; }
.list-item:last-child { border-bottom:none; }
.kpi { font-size:40rpx; font-weight:800; }
.input { background:#f8fafc; border:1rpx solid #dbeafe; border-radius:14rpx; padding:20rpx; margin-top:16rpx; }
.section-title { font-size:28rpx; font-weight:700; margin-bottom:16rpx; }

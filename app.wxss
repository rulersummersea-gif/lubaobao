page {
  background: #f5f7fb;
  color: #0f172a;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 32rpx;
  line-height: 1.58;
}

.container { padding: 30rpx; }

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 8rpx 30rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.35;
}

.sub {
  color: #475569;
  font-size: 30rpx;
  line-height: 1.6;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
}

.btn-primary,
.btn-secondary {
  border-radius: 18rpx;
  min-height: 118rpx;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.btn-primary {
  background: #1d4ed8;
  color: #ffffff;
}

.btn-secondary {
  background: #e2e8f0;
  color: #0f172a;
}

.tag {
  display: inline-block;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.tag-normal { background: #dcfce7; color: #166534; }
.tag-warn { background: #fef3c7; color: #92400e; }
.tag-danger { background: #fee2e2; color: #991b1b; }

.list-item {
  padding: 26rpx 0;
  border-bottom: 1rpx solid #dbe3ef;
}
.list-item:last-child { border-bottom: none; }

.kpi {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.2;
}

.input,
.picker {
  background: #f8fafc;
  border: 2rpx solid #cbd5e1;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-top: 14rpx;
  min-height: 96rpx;
  font-size: 32rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
  line-height: 1.35;
}

.helper {
  font-size: 30rpx;
  color: #475569;
  line-height: 1.6;
}

<view class="container" wx:if="{{detail}}">
  <view class="card">
    <view class="title">{{detail.boilerName}}</view>
    <view class="sub">{{detail.time}}</view>
    <view class="sub">{{detail.summary}}</view>
  </view>
  <view class="card">
    <view class="section-title">检测明细</view>
    <block wx:for="{{detail.items}}" wx:key="name">
      <view class="list-item row">
        <view>
          <view>{{item.priority}}. {{item.name}}</view>
          <view wx:if="{{item.method}}" class="sub">工具：{{item.method}}</view>
          <view wx:if="{{item.normalRange}}" class="sub">正常范围：{{item.normalRange}}</view>
          <view wx:if="{{item.meaning}}" class="sub">意义：{{item.meaning}}</view>
          <view wx:if="{{item.maintenance}}" class="sub">维护：{{item.maintenance}}</view>
        </view>
        <view style="text-align:right;">
          <view>{{item.value}}</view>
          <view class="sub">{{item.statusText}}</view>
        </view>
      </view>
    </block>
  </view>
  <view class="card">
    <view class="section-title">诊断建议</view>
    <block wx:for="{{detail.diagnosis}}" wx:key="title">
      <view class="list-item">
        <view>{{item.title}}</view>
        <view class="sub">{{item.advice}}</view>
      </view>
    </block>
  </view>
</view>

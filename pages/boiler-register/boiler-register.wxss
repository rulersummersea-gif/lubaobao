@import '../../app.wxss';

.field { margin-top: 22rpx; }
.label {
  color: #1e293b;
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.input,
.picker {
  background: #f8fafc;
  border: 2rpx solid #cbd5e1;
  border-radius: 14rpx;
  min-height: 96rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #0f172a;
}

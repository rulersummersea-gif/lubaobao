<view class="container">
  <view class="card">
    <view class="title">发起巡检</view>
    <view class="sub">当前锅炉：{{currentBoiler ? currentBoiler.name : '未选择'}}</view>
    <view class="btn-secondary" bindtap="goChooseBoiler">选择锅炉</view>
  </view>

  <view class="card">
    <view class="title">检测准备</view>
    <view class="sub">材料包编码：{{materialPackCode || '未扫码'}}</view>
    <view class="btn-secondary" bindtap="scanPack">扫码材料包</view>
    <view style="height:16rpx"></view>
    <view class="btn-secondary" bindtap="useTestPack">使用测试包 PACK-001</view>
    <view style="height:16rpx"></view>
    <view class="btn-secondary" bindtap="chooseInspectionImage">拍照/选择图片</view>
    <view class="tip-box">请先选择锅炉、校验材料包，再拍摄检测图片发起巡检。</view>
    <view wx:if="{{previewImage}}" class="preview-box">
      <image class="preview-img" src="{{previewImage}}" mode="aspectFill"></image>
    </view>
  </view>

  <view class="card">
    <view class="btn-primary" bindtap="startInspection">开始巡检</view>
  </view>
</view>

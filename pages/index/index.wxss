@import '../../app.wxss';

.hero {
  overflow: hidden;
  padding-bottom: 24rpx;
}

.hero-meta {
  margin-top: 12rpx;
  display: grid;
  gap: 4rpx;
}

.hero-score {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #eff6ff;
  border: 2rpx solid #bfdbfe;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
}

.score-label {
  color: #334155;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.score-number {
  font-size: 70rpx;
  font-weight: 800;
  line-height: 1;
  margin-top: 8rpx;
  color: #0f172a;
}

.factory-actions {
  margin-top: 22rpx;
  background: #f8fafc;
  border: 2rpx solid #dbe3ef;
  border-radius: 16rpx;
  padding: 20rpx;
}

.management-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.manage-btn {
  min-height: 108rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #ffffff;
  color: #0f172a;
  border: 2rpx solid #cbd5e1;
  border-radius: 16rpx;
}

.manage-wide {
  grid-column: 1 / 3;
}

.manage-title,
.action-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
}

.primary-action,
.secondary-action {
  min-height: 118rpx;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 18rpx;
}

.primary-action {
  background: #1d4ed8;
  color: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(29, 78, 216, 0.22);
}

.secondary-action {
  margin-top: 16rpx;
  background: #eef2f7;
  color: #0f172a;
  border: 2rpx solid #d6dee9;
}

.manage-btn:active,
.primary-action:active,
.secondary-action:active { opacity: .86; }

.stat-card { margin-bottom: 0; }

@media (max-width: 360px) {
  .management-grid {
    grid-template-columns: 1fr;
  }

  .manage-wide {
    grid-column: auto;
  }
}

<view class="container">
  <view class="hero card">
    <view class="title">{{enterprise.name || 'XXXXX有限公司'}}</view>
    <view class="hero-meta">
      <view class="sub">当前用户：{{user.name || '-'}}</view>
      <view class="sub">当前锅炉：{{currentBoiler.name || '未选择'}}</view>
    </view>

    <view class="hero-score">
      <view>
        <view class="score-label">锅炉健康评分</view>
        <view class="score-number">72</view>
      </view>
      <view class="tag tag-warn">持续关注</view>
    </view>

    <view class="factory-actions">
      <view class="section-title">工厂管理</view>
      <view class="management-grid">
        <view class="manage-btn" bindtap="goActivate">
          <view class="manage-title">激活材料包</view>
        </view>
        <view class="manage-btn" bindtap="goBoilerRegister">
          <view class="manage-title">信息注册</view>
        </view>
        <view class="manage-btn manage-wide" bindtap="goBoilers">
          <view class="manage-title">选择锅炉</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">快捷操作</view>
    <view class="primary-action" bindtap="goInspect">
      <view class="action-title">开始巡检</view>
    </view>
    <view class="secondary-action" bindtap="goReport">
      <view class="action-title">查看月报</view>
    </view>
  </view>

  <view class="grid-2">
    <block wx:for="{{stats}}" wx:key="label">
      <view class="card stat-card">
        <view class="kpi">{{item.value}}</view>
        <view class="sub">{{item.label}}</view>
      </view>
    </block>
  </view>

  <view class="card">
    <view class="row" style="margin-bottom:12rpx;">
      <view class="section-title">异常提醒</view>
      <view class="sub" bindtap="goAlerts" style="color:#2563eb;">查看全部</view>
    </view>
    <block wx:if="{{alerts.length}}">
      <block wx:for="{{alerts}}" wx:key="title">
        <view class="list-item">
          <view class="row">
            <view>
              <view>{{item.title}}</view>
              <view class="sub">{{item.desc}}</view>
            </view>
            <view class="tag tag-warn">预警</view>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="sub">暂无异常提醒</view>
  </view>

  <view class="card">
    <view class="section-title">最近巡检摘要</view>
    <view class="sub">最近一次结果：pH、磷酸根、电导率/TDS预警，建议调整加药并加强排污后复测。</view>
  </view>
</view>
